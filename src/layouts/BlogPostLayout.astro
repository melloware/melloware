---
import BaseLayout from './BaseLayout.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  description?: string;
  banner?: ImageMetadata;
}

const { title, date, tags, description, banner } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="blog-post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <div class="tags">
            {tags.map(tag => (
              <a href={`/tags/${tag.toLowerCase()}/`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </div>
      <h1>{title}</h1>
      {banner && (
        <img
          src={banner.src}
          alt={title}
          width={banner.width}
          height={banner.height}
          class="banner"
        />
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    background-color: var(--bg-secondary);
    color: var(--text-muted);
    border: 1px solid var(--border);
    font-weight: 500;
  }

  .tag:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 1rem;
    line-height: 1.25;
  }

  .banner {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-top: 1rem;
  }

  .prose :global(img) {
    border-radius: 6px;
    display: block;
    margin: 1.5rem auto;
  }

  .prose :global(h2) {
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.35rem;
  }
</style>
