---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <span class="copyright">&copy; {year} Melloware. All rights reserved.</span>
    <div class="badges">
      <a href="https://stackoverflow.com/users/502366/melloware" aria-label="Stack Overflow reputation">
        <img
          src="https://img.shields.io/stackexchange/stackoverflow/r/502366?style=flat-square&label=Stack+Overflow"
          alt="Stack Overflow reputation"
          loading="lazy"
        />
      </a>
      <a href="https://github.com/melloware" aria-label="GitHub followers">
        <img
          src="https://img.shields.io/github/followers/melloware?style=flat-square&label=GitHub"
          alt="GitHub followers"
          loading="lazy"
        />
      </a>
      <a href="https://github.com/sponsors/melloware" aria-label="GitHub Sponsors">
        <img
          src="https://img.shields.io/github/sponsors/melloware?style=flat-square&color=gold&label=Sponsors"
          alt="GitHub Sponsors"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 1.25rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .copyright {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .badges a {
    display: inline-flex;
  }
</style>
