---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="not-found">
    <p class="code">404</p>
    <h1>Page Not Found</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href="/">Go home &rarr;</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 0;
  }

  .code {
    font-size: 6rem;
    font-weight: 700;
    color: var(--border);
    margin: 0;
    line-height: 1;
  }

  h1 {
    margin-top: 0.5rem;
  }

  p {
    color: var(--text-muted);
  }

  a {
    font-weight: 500;
  }
</style>
